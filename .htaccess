RewriteEngine On

# Blokir directory listing (biar tidak bisa lihat daftar file)
Options -Indexes

# 1. Lewati jika file/folder benar-benar ada (untuk aset di masa depan)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Blokir akses ke webhook tanpa .php → 404
RewriteRule ^webhook$ - [R=404,L]

# 3. Akses root folder ini (/jwdpoloap/) → langsung ke loginwa.php
RewriteRule ^$ loginwa.php [L]

# 4. Semua request lain di dalam folder ini → tambahkan .php secara internal
RewriteRule ^(.+)$ $1.php [L]

# Blokir akses file sensitif (log, txt, dll)
<Files ~ "\.(log|txt|yaml)$">
    Order allow,deny
    Deny from all
</Files>